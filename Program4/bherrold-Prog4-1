import csv
def introduction():
    print('''
Welcome to the Marathon Runners Race Time Program
In this program you can read and write into the file for:

Each runners and their times in the following three marathons: 
            Boston, Chicago, and New York.
      
===================================================================
''')

#Main Function
def main():
    filename = "runners.txt"
    runners = read_data(filename)

    while True:
        
        print('''Menu Options. Choose 1, 2, 3, or 4 to continue.
                    1. Display all runners and times for their races.
                    2. Display a runners individual race average (in minutes)
                    3. Add a new runner and race time
                    4. Save and Exit.                               ''')
        
        choice = input("\n Please Enter your choice, 1, 2, 3, or 4: ")

        if choice == "1":
            display_all_results(runners)

        elif choice == "2":
            display_runner_time(runners)

        elif choice == "3":
            runners = add_runner(runners)

        elif choice == "4":
            store_data_and_exit(filename, runners)

            print(input("Press Enter to exit the program..."))
            break


#Function 1 - Which is meant to read the data
def read_data(filename):

    # Create empty list for runner dictionaries
    runners = []

    try:
        #Open file
        infile = open(filename, "r", newline="")

        #Read as csv-formatting
        reader = csv.DictReader(infile, fieldnames=["Name", "Boston", "Chicago", "New York"])

        #Loops through each row
        for row in reader:
            d = {}
            d["Name"] = row["Name"]
            d["Boston"] = int(row["Boston"])
            d["Chicago"] = int(row["Chicago"])
            d["New York"] = int(row["New York"])

            #Appends the dictionary to the list
            runners.append(d)

        infile.close()

        #Checkpoint for file load
        print("\nrunners.txt has loaded successfully.")
        print("Total Runners in file: ", len(runners), "\n")

    except IOError:
        print("\nError: runners.txt was unable to open.\n")

        
    #Return the new appended List
    return runners


#Function 2 - This will display ALL data for the runners
def display_all_results(runners):
        if len(runners) == 0:
            print("\nNo runner data is available.")
            return
        
        #Top line formatting for time displays
        print("\n%-10s %8s %8s %10s" %  ("Runner", "Boston", " Chicago", "New York"))
        print("==================================================")

        #Display Loop for each runner in the dictionary
        for runner in runners:
            print("%-10s %8s %8s %10s" % (runner["Name"], runner["Boston"], runner["Chicago"], runner["New York"]))

        print()

#Function 3 - Individual Runner Time check
def display_runner_time(runners):
    if len(runners) == 0:
        print("\nNo runner data is available.")
        return
    
    #prompt to request runners name
    runner_name = input("\nPlease enter an existing runners name to search: ")

        #Loop to check for runner in dictionary
    for runner in runners:    
        found = False        
        
         #Check for matching name
        if runner["Name"].lower() == runner_name.lower():
                     
            #Calculate the runners average run time in minutes
            num_of_races = 3    #Boston, Chicago, New York
            total_run_times = runner["Boston"] + runner["Chicago"] + runner["New York"]
            average_time = round(total_run_times / num_of_races)

            #Display the runner name, and then run time
            print("\n Runner name: %s" % runner["Name"] + "\n Average Run time: %d minutes\n" % average_time)
            found = True    
            break
    if found == False:
        print("\nRunner not found.\n")

#Function 4 - Adding a new runner, including their times in the order of Boston, Chicago, New York.
def add_runner(runners):

    #Prompts the user for runners name, and the times in order.
    runner_name = input("\nPlease enter a name for the runner you would like to add: ")
    
    if runner_name == "" and runner_name != runner_name.isalpha():
            print("\n Error: You must enter a name, please try again.")
            return runners
    
    for runner in runners:
        if runner["Name"].lower() == runner_name.lower():
            print("\n Error: That name already exists, please try again.")
            return runners
        

        try:
            #Prompt race time for the new runner.
            boston_time_entry = int(input("\nPlease enter the time for " + runner_name + " in the Boston Marathon (in minutes): "))
            chicago_time_entry = int(input("\nPlease enter the time for " + runner_name + " in the Chicago Marathon (in minutes): "))
            newyork_time_entry = int(input("\nPlease enter the time for " + runner_name + " in the New York Marathon (in minutes): "))


        #This creates the new dictionary reference for the runner
            d = {}
            d["Name"] = runner_name
            d["Boston"] = boston_time_entry
            d["Chicago"] = chicago_time_entry
            d["New York"] = newyork_time_entry

            #Appends the new runner to the dictionary.
            runners.append(d)

            print("\n   Runner %s has been added successfully. \n" % runner_name)
    
        except ValueError:
            print("\n   Error: Please enter a valid time (in minutes.)\n")

        return runners

#Function 5 - Saving the added runners.
def store_data_and_exit(filename, runners):
    try:
        #Open file to write to
        outfile = open(filename, "w", newline= "")

        #Write to file with the csv-format
        fieldnames = ["Name", "Boston", "Chicago", "New York"] 
        writer = csv.DictWriter(outfile, fieldnames=fieldnames)

        #Write each runner dictionary to the file
        for runner in runners:
            writer.writerow(runner)

        outfile.close()
        print("\nRunner data has been saved.")

    except IOError:
        print("\nError: The data was unable to be saved to the data file.")
        

main()
introduction()
